# Local development env vars. Copy this file to `.env.local` and fill in
# real values. `.env.local` is gitignored — never commit secrets.
#
# Fast path on a machine that's already linked to the Vercel project:
#   vercel link && vercel env pull .env.local
# That pulls every var below (plus a handful Neon/Vercel inject for
# tool compatibility — Prisma URL aliases, raw PG* connection pieces,
# etc. — that this codebase does not read directly).
#
# Manual path: fill the values below by hand from each provider's
# dashboard. The list here is the complete set the codebase touches —
# anything missing here means the code does not read it.

# ── Site identity ───────────────────────────────────────────────────
# Public URL the site + admin + API are reachable at. Used by Payload
# to build absolute links in outbound mail (password reset, account
# verification) and as the implicit CORS/CSRF allowlist origin.
#
# Locally: leave empty — code defaults to http://localhost:3000.
# Vercel Preview: leave empty — code auto-derives from VERCEL_URL.
# Vercel Production: set to the public URL —
#   https://home2host.vercel.app today, https://home2host.com after
#   the Stage 6 DNS switch.
NEXT_PUBLIC_SERVER_URL=

# ── Payload + database ──────────────────────────────────────────────
# Neon Postgres connection string (pooled). Required.
#   format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# Random ≥32-char string used by Payload to sign JWTs + cookies.
# Generate locally with: `openssl rand -hex 32`
# Production + Preview + Development MUST share the same secret on Vercel
# so sessions survive between environments.
PAYLOAD_SECRET=

# ── Media storage ───────────────────────────────────────────────────
# Vercel Blob token (storage adapter). Required for uploads to land in
# Blob; without it, Payload writes to /tmp and the admin shows broken
# image URLs. Get from Vercel → Storage → your blob store → Settings.
BLOB_READ_WRITE_TOKEN=

# ── Contact-form rate limit ─────────────────────────────────────────
# Upstash Redis REST creds (sliding-window rate limiter). Optional —
# the limiter fails OPEN if either var is empty, so local dev works
# without an Upstash account. Set both in production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Outbound mail (SMTP) ────────────────────────────────────────────
# Hostinger SMTP creds. Drives BOTH the contact form (visitor → owner)
# AND Payload admin email (password reset, account verification, any
# future admin-initiated mail). All four required for sending to work:
# without them the contact form short-circuits with an inline
# "misconfigured" error, and Payload falls back to a console-only mail
# transport (admin "Forgot password" prints to dev log instead of
# delivering — fine for local dev, breaks password recovery in prod).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@home2host.com
SMTP_PASSWORD=

# Optional override for who receives form submissions. Defaults to
# SMTP_USER if unset, which is what production uses.
# CONTACT_RECIPIENT=

# ── Analytics ───────────────────────────────────────────────────────
# Google Analytics 4 measurement ID. Same value as the live WordPress
# site so GA history is preserved through the Stage 6 DNS switch.
# Public (NEXT_PUBLIC_*) — ships to the browser; not a secret.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
